# Ziggy Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM API (Required - choose one)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# =============================================================================
# OAuth Providers (Optional - add as needed)
# =============================================================================

# Google (for Gmail, Calendar, Drive, etc.)
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
# NOTE: Google uses a credentials.json file instead of env vars
# Download OAuth client JSON and save to ~/.apex/google_credentials.json

# Microsoft (for Outlook, OneDrive, Teams, etc.)
# Register at: https://portal.azure.com/ → Azure AD → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Discord
# Register at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# DISCORD_BOT_TOKEN=  # Optional, only if you want bot features

# Slack
# Register at: https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# GitHub
# Register at: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Spotify
# Register at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# =============================================================================
# API Key Providers (Optional - simpler setup)
# =============================================================================

# Twilio (for SMS)
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Todoist
# Get from: https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=

# Notion
# Create integration at: https://www.notion.so/my-integrations
NOTION_API_KEY=

# Linear
# Get from: https://linear.app/settings/api
LINEAR_API_KEY=

# =============================================================================
# Advanced Settings
# =============================================================================

# If using the central OAuth broker instead of local credentials
# ZIGGY_BROKER_URL=https://auth.ziggy.ai
# ZIGGY_USE_CLOUD=true
